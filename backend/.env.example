# Database (overridden by docker-compose environment for container networking)
DATABASE_URL=postgresql+asyncpg://dermatoai:dermatoai@localhost:5432/dermatoai
DATABASE_URL_SYNC=postgresql://dermatoai:dermatoai@localhost:5432/dermatoai

# JWT
JWT_SECRET_KEY=change-this-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage (overridden by docker-compose environment)
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
S3_BUCKET_NAME=dermatoai-images
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Model
MODEL_PATH=/app/model/model.pt
MODEL_VERSION=1.0.0
INFERENCE_MAX_WORKERS=2

# App
APP_NAME=DermatoIA
APP_VERSION=1.0.0
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081"]

# Firebase (for push notifications)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
